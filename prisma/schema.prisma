// Luxe Swiss Watch CRM — Prisma schema
// Engine: MySQL. All business entities use soft delete via `deletedAt`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Enums ─────────────────────────

enum UserRole {
  MANAGER
  ASSOCIATE
}

enum ClientTier {
  STANDARD
  PRIORITY
  VIP
}

enum PipelineStage {
  PROSPECT
  CONTACTED
  ENGAGED
  APPOINTMENT
  NEGOTIATION
  WON
  LOST
}

enum TaskType {
  MESSAGE
  CALL
  APPOINTMENT
  FOLLOW_UP
  SERVICE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum ActivityType {
  NOTE
  MESSAGE
  CALL
  APPOINTMENT
  STAGE_CHANGE
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  STAGE_CHANGE
  LOGIN
  LOGOUT
}

enum NotificationType {
  SLA_BREACH
  TASK_OVERDUE
  TASK_ASSIGNED
  CLIENT_ASSIGNED
  STAGE_CHANGE
  SYSTEM
}

// ───────────────────────── Users ─────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ASSOCIATE)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.DateTime(3)
  updatedAt    DateTime @updatedAt @db.DateTime(3)
  deletedAt    DateTime? @db.DateTime(3)

  clients       Client[]       @relation("ClientOwner")
  activities    Activity[]     @relation("ActivityActor")
  sales         Sale[]         @relation("SaleAssociate")
  tasks         Task[]         @relation("TaskAssignee")
  createdTasks  Task[]         @relation("TaskCreator")
  stageChanges  PipelineState[] @relation("StageChangedBy")
  auditLogs     AuditLog[]
  notifications Notification[]

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

// ───────────────────────── Clients ─────────────────────────

model Client {
  id            String     @id @default(cuid())
  name          String
  phone         String
  email         String?
  tier          ClientTier @default(STANDARD)
  stage         PipelineStage @default(PROSPECT)
  ownerId       String
  birthday      DateTime?  @db.Date
  anniversary   DateTime?  @db.Date
  notes         String?    @db.Text
  wishlist      Json?
  collection    Json?
  lastContactAt DateTime?  @db.DateTime(3)
  createdAt     DateTime   @default(now()) @db.DateTime(3)
  updatedAt     DateTime   @updatedAt @db.DateTime(3)
  deletedAt     DateTime?  @db.DateTime(3)

  owner         User            @relation("ClientOwner", fields: [ownerId], references: [id])
  activities    Activity[]
  sales         Sale[]
  tasks         Task[]
  stageHistory  PipelineState[]

  @@index([name])
  @@index([phone])
  @@index([ownerId])
  @@index([stage])
  @@index([tier])
  @@index([deletedAt])
  @@index([lastContactAt])
  @@map("clients")
}

// ───────────────────────── Activities ─────────────────────────

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  clientId  String
  actorId   String
  summary   String       @db.VarChar(500)
  body      String?      @db.Text
  metadata  Json?
  occurredAt DateTime    @default(now()) @db.DateTime(3)
  createdAt DateTime     @default(now()) @db.DateTime(3)
  deletedAt DateTime?    @db.DateTime(3)

  client Client @relation(fields: [clientId], references: [id])
  actor  User   @relation("ActivityActor", fields: [actorId], references: [id])

  @@index([clientId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([type])
  @@index([deletedAt])
  @@map("activities")
}

// ───────────────────────── Tasks ─────────────────────────

model Task {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(300)
  description  String?      @db.Text
  type         TaskType
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(NORMAL)
  dueDate      DateTime     @db.DateTime(3)
  completedAt  DateTime?    @db.DateTime(3)
  clientId     String
  assigneeId   String
  createdById  String
  autoGenerated Boolean     @default(false)
  sourceJob    String?      @db.VarChar(64)
  createdAt    DateTime     @default(now()) @db.DateTime(3)
  updatedAt    DateTime     @updatedAt @db.DateTime(3)
  deletedAt    DateTime?    @db.DateTime(3)

  client    Client @relation(fields: [clientId], references: [id])
  assignee  User   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User   @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([dueDate, status])
  @@index([assigneeId, status])
  @@index([clientId])
  @@index([type])
  @@index([priority])
  @@index([deletedAt])
  @@map("tasks")
}

// ───────────────────────── Sales ─────────────────────────

model Sale {
  id            String   @id @default(cuid())
  clientId      String
  associateId   String
  product       String   @db.VarChar(300)
  reference     String?  @db.VarChar(128)
  amount        Decimal  @db.Decimal(14, 2)
  currency      String   @default("USD") @db.Char(3)
  purchaseDate  DateTime @db.DateTime(3)
  metadata      Json?
  createdAt     DateTime @default(now()) @db.DateTime(3)
  updatedAt     DateTime @updatedAt @db.DateTime(3)
  deletedAt     DateTime? @db.DateTime(3)

  client    Client @relation(fields: [clientId], references: [id])
  associate User   @relation("SaleAssociate", fields: [associateId], references: [id])

  @@index([associateId, purchaseDate])
  @@index([clientId])
  @@index([purchaseDate])
  @@index([deletedAt])
  @@map("sales")
}

// ───────────────────────── Pipeline States ─────────────────────────

model PipelineState {
  id          String        @id @default(cuid())
  clientId    String
  stage       PipelineStage
  fromStage   PipelineStage?
  note        String        @db.Text
  changedById String
  createdAt   DateTime      @default(now()) @db.DateTime(3)

  client    Client @relation(fields: [clientId], references: [id])
  changedBy User   @relation("StageChangedBy", fields: [changedById], references: [id])

  @@index([stage])
  @@index([clientId, createdAt])
  @@map("pipeline_states")
}

// ───────────────────────── Templates ─────────────────────────

model Template {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(200)
  category  String   @db.VarChar(80)
  body      String   @db.Text
  variables Json
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @db.DateTime(3)
  updatedAt DateTime @updatedAt @db.DateTime(3)
  deletedAt DateTime? @db.DateTime(3)

  @@index([category])
  @@index([active])
  @@index([deletedAt])
  @@map("templates")
}

// ───────────────────────── Audit Logs ─────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  action     AuditAction
  entityType String      @db.VarChar(64)
  entityId   String      @db.VarChar(64)
  before     Json?
  after      Json?
  metadata   Json?
  ip         String?     @db.VarChar(64)
  userAgent  String?     @db.VarChar(300)
  createdAt  DateTime    @default(now()) @db.DateTime(3)

  actor User @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

// ───────────────────────── Notifications ─────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(200)
  body      String           @db.Text
  link      String?          @db.VarChar(500)
  readAt    DateTime?        @db.DateTime(3)
  metadata  Json?
  createdAt DateTime         @default(now()) @db.DateTime(3)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}
