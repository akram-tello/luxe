# --- Database ---
# MySQL connection string (required)
DATABASE_URL="mysql://user:password@localhost:3306/luxe_crm"

# --- Auth ---
# 32+ character random secret, used for JWT signing
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"
# Session duration in seconds (default 12 hours)
AUTH_SESSION_TTL="43200"

# --- Cron / Jobs ---
# Shared secret required in X-Cron-Secret header to trigger job endpoints
CRON_SECRET="change-me-to-another-long-random-string"

# --- Store ---
# Name injected into message templates as {{store_name}}
STORE_NAME="Luxe Geneva Boutique"

# --- App ---
NEXT_PUBLIC_APP_NAME="Luxe CRM"
